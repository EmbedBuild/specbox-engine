# SDD-JPS Engine — Environment Variables
# Copy this file to .env and fill in your values

# MCP Server Transport
MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Dashboard authentication (REQUIRED in production, optional for local dev)
DASHBOARD_TOKEN=

# Dashboard CORS origin (restrict cross-origin access in production)
# Leave empty to disable CORS headers (same-origin only — recommended for production)
# Set to "*" for local development, or to a specific origin like "https://your-domain.com"
DASHBOARD_CORS_ORIGIN=

# Remote telemetry (optional — fire-and-forget reporting to centralized MCP)
DEV_ENGINE_MCP_URL=

# Engine paths (defaults work for Docker; override for local dev)
# ENGINE_PATH=/app
# STATE_PATH=/data/state

# Logging format: "console" (default) or "json"
# LOG_FORMAT=console
