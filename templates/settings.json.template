{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "WebFetch(domain:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-first-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node .claude/hooks/healing-budget-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pipeline-phase-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node .claude/hooks/stripe-safety-guard.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-first-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node .claude/hooks/healing-budget-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pipeline-phase-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node .claude/hooks/stripe-safety-guard.mjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(.*--no-verify.*)",
            "command": "node .claude/hooks/no-bypass-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(.*push.*--force.*)",
            "command": "node .claude/hooks/no-bypass-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(.*push.*-f .*)",
            "command": "node .claude/hooks/no-bypass-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(.*reset --hard.*)",
            "command": "node .claude/hooks/no-bypass-guard.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/read-tracker.mjs",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(.*git commit.*)",
            "command": "node .claude/hooks/commit-spec-guard.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Bash(.*git commit.*)",
            "command": "node .claude/hooks/pre-commit-lint.mjs",
            "timeout": 60
          },
          {
            "type": "command",
            "if": "Bash(.*git commit.*)",
            "command": "node .claude/hooks/e2e-gate.mjs",
            "timeout": 15
          },
          {
            "type": "command",
            "if": "Bash(.*git commit.*)",
            "command": "node .claude/hooks/checkpoint-freshness-guard.mjs",
            "timeout": 5
          },
          {
            "type": "command",
            "if": "Bash(.*git push.*)",
            "command": "node .claude/hooks/uc-lifecycle-guard.mjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "if": "Write(src/.*)",
            "command": "node .claude/hooks/spec-guard.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Write(lib/.*)",
            "command": "node .claude/hooks/spec-guard.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Write(presentation/pages/.*)",
            "command": "node .claude/hooks/design-gate.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Write(src/pages/.*)",
            "command": "node .claude/hooks/design-gate.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Write(app/.*)",
            "command": "node .claude/hooks/design-gate.mjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(src/.*)",
            "command": "node .claude/hooks/spec-guard.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Edit(lib/.*)",
            "command": "node .claude/hooks/spec-guard.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Edit(presentation/pages/.*)",
            "command": "node .claude/hooks/design-gate.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Edit(src/pages/.*)",
            "command": "node .claude/hooks/design-gate.mjs",
            "timeout": 10
          },
          {
            "type": "command",
            "if": "Edit(app/.*)",
            "command": "node .claude/hooks/design-gate.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/on-session-end.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "trello": {
    "boardId": "",
    "_comment": "Dejar vacío si no usa Trello. Rellenar con el ID del board tras ejecutar setup_board."
  },
  "acceptance": {
    "framework": "gherkin",
    "language": "es",
    "features_path": {
      "flutter": "test/acceptance/features/",
      "react": "tests/acceptance/features/",
      "go": "tests/acceptance/features/",
      "python": "tests/acceptance/features/",
      "google-apps-script": "tests/acceptance/features/"
    }
  },
  "stitch": {
    "projectId": "{STITCH_PROJECT_ID}",
    "deviceType": "DESKTOP",
    "modelId": "GEMINI_3_PRO"
  },
  "plane": {
    "defaultProject": "{PLANE_PROJECT}",
    "defaultState": "Backlog",
    "projectId": "{PLANE_PROJECT_ID}",
    "defaultAssignee": "{USER_ID}"
  },
  "veg": {
    "enabled": true,
    "image_provider": {
      "primary": "canva",
      "fallback": "lansespirit",
      "maxImagesPerScreen": 5,
      "defaultAspectRatio": "16:9",
      "stockSearchFirst": false,
      "_setup_instructions": "Primary: Canva MCP (free with Canva Pro/Premium). Fallback: lansespirit (paid per image). See veg.mcpServers below.",
      "_cost_warning": "Canva: €0 with Pro/Premium subscription. Fallback: OpenAI ($0.02-0.19/img), Gemini ($0.02-0.06/img)"
    },
    "mcpServers": {
      "_comment": "Copy the provider(s) you want into .vscode/mcp.json or claude_desktop_config.json",
      "canva": {
        "command": "npx",
        "args": ["-y", "mcp-remote@latest", "https://mcp.canva.com/mcp"],
        "_requires": "Canva Pro or Premium subscription. Auth via OAuth (browser popup). No API key needed.",
        "_cost": "€0 additional — included in Canva subscription"
      },
      "freepik": {
        "command": "npx",
        "args": ["-y", "mcp-remote", "https://api.freepik.com/mcp", "--header", "x-freepik-api-key:${FREEPIK_API_KEY}"],
        "_requires": "FREEPIK_API_KEY — Get at https://www.freepik.com/api — Paid plan required for generation",
        "_cost": "Pay-per-use (Essential €5/mo, Premium €10/mo, Premium+ €22.50/mo)"
      },
      "image-gen": {
        "command": "python",
        "args": ["-m", "image_gen_mcp"],
        "env": {
          "OPENAI_API_KEY": "${OPENAI_API_KEY}",
          "GOOGLE_API_KEY": "${GOOGLE_API_KEY}"
        },
        "_requires": "pip install image-gen-mcp — Needs OPENAI_API_KEY and/or GOOGLE_API_KEY with active billing",
        "_cost": "OpenAI: $0.02-0.19/img, Gemini: $0.02-0.06/img"
      }
    },
    "motion": {
      "enabled": true,
      "flutter": {
        "package": "flutter_animate",
        "version": "^4.5.2"
      },
      "react": {
        "library": "motion",
        "version": "^12.35.0"
      }
    },
    "defaults": {
      "fallback_mode": "uniform",
      "fallback_motion_level": "moderate"
    }
  }
}
