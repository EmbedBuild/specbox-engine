{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "WebFetch(domain:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "Bash",
          "command_pattern": "git commit"
        },
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-lint.sh",
            "blocking": true,
            "timeout": 60000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/on-session-end.sh",
            "blocking": false,
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "stitch": {
    "projectId": "{STITCH_PROJECT_ID}",
    "deviceType": "DESKTOP",
    "modelId": "GEMINI_3_PRO"
  },
  "plane": {
    "defaultProject": "{PLANE_PROJECT}",
    "defaultState": "Backlog",
    "projectId": "{PLANE_PROJECT_ID}",
    "defaultAssignee": "{USER_ID}"
  },
  "veg": {
    "enabled": true,
    "image_provider": {
      "primary": "freepik",
      "fallback": "lansespirit",
      "maxImagesPerScreen": 5,
      "defaultAspectRatio": "16:9",
      "stockSearchFirst": true,
      "_setup_instructions": "See veg.mcpServers below for required MCP config. Each provider needs an active API key with credits.",
      "_cost_warning": "Image generation costs money: Freepik (plan-based), OpenAI ($0.02-0.19/img), Gemini ($0.02-0.06/img)"
    },
    "mcpServers": {
      "_comment": "Copy the provider(s) you want into .vscode/mcp.json or claude_desktop_config.json",
      "freepik": {
        "command": "npx",
        "args": ["-y", "mcp-remote", "https://api.freepik.com/mcp", "--header", "x-freepik-api-key:${FREEPIK_API_KEY}"],
        "_requires": "FREEPIK_API_KEY — Get at https://www.freepik.com/api — Paid plan required for generation"
      },
      "image-gen": {
        "command": "python",
        "args": ["-m", "image_gen_mcp"],
        "env": {
          "OPENAI_API_KEY": "${OPENAI_API_KEY}",
          "GOOGLE_API_KEY": "${GOOGLE_API_KEY}"
        },
        "_requires": "pip install image-gen-mcp — Needs OPENAI_API_KEY and/or GOOGLE_API_KEY with active billing"
      }
    },
    "motion": {
      "enabled": true,
      "flutter": {
        "package": "flutter_animate",
        "version": "^4.5.2"
      },
      "react": {
        "library": "motion",
        "version": "^12.35.0"
      }
    },
    "defaults": {
      "fallback_mode": "uniform",
      "fallback_motion_level": "moderate"
    }
  }
}
