{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "WebFetch(domain:*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "stitch": {
    "projectId": "{STITCH_PROJECT_ID}",
    "deviceType": "DESKTOP",
