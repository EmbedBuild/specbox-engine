{
  "$schema": "JPS Dev Engine v3.5.0 - Agent Teams Configuration",
  "team": {
    "name": "{PROJECT_NAME}",
    "description": "Equipo de desarrollo para {PROJECT_NAME}",
    "maxConcurrentTeammates": 3
  },
  "roles": {
    "Lead": {
      "model": "opus",
      "prompt": "agent-teams/prompts/lead-agent.md",
      "responsibilities": [
        "Planificacion y coordinacion",
        "Revision de PRs",
        "Decisiones de arquitectura"
      ],
      "fileOwnership": ["doc/plans/", "CLAUDE.md"],
      "canDelegate": true,
      "canImplement": false
    },
    "DesignSpecialist": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/design-specialist.md",
      "responsibilities": [
        "Generacion de diseños via Stitch MCP",
        "Conversion HTML a codigo",
        "Design system"
      ],
      "fileOwnership": ["doc/design/"],
      "priority": "FIRST",
      "note": "Lanzar primero: Stitch tarda minutos por pantalla"
    },
    "FlutterSpecialist": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/flutter-specialist.md",
      "responsibilities": [
        "Features Flutter (BLoC + Freezed)",
        "Responsive layouts (3 breakpoints)",
        "Widgets como clases separadas"
      ],
      "fileOwnership": ["lib/presentation/", "lib/data/", "lib/domain/", "lib/core/widgets/"]
    },
    "ReactSpecialist": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/react-specialist.md",
      "responsibilities": [
        "Next.js App Router",
        "Server Components + TanStack Query",
        "Tailwind CSS"
      ],
      "fileOwnership": ["src/app/", "src/components/", "src/hooks/", "src/stores/"]
    },
    "PythonBackend": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/python-backend.md",
      "responsibilities": [
        "FastAPI endpoints",
        "SQLAlchemy models",
        "Pydantic schemas"
      ],
      "fileOwnership": ["src/api/", "src/models/", "src/schemas/", "src/services/"]
    },
    "DBInfra": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/db-infra.md",
      "responsibilities": [
        "Supabase/Neon/Firebase",
        "Migraciones y schemas",
        "RLS policies",
        "Stripe integracion"
      ],
      "fileOwnership": ["supabase/", "migrations/", "prisma/"]
    },
    "AppScriptSpecialist": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/appscript-specialist.md",
      "responsibilities": [
        "Google Apps Script (clasp + TypeScript)",
        "Web Apps, Add-ons, Triggers",
        "Integraciones Google Workspace (Sheets, Gmail, Drive)"
      ],
      "fileOwnership": ["src/**/*.ts", "src/**/*.html", "html/", ".clasp.json", "appsscript.json", "dist/"]
    },
    "QAReviewer": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/qa-reviewer.md",
      "responsibilities": [
        "Tests unitarios, widget, integracion",
        "Coverage 85%+",
        "Edge cases + fuzz testing"
      ],
      "fileOwnership": ["test/", "tests/", "__tests__/"]
    },
    "AcceptanceTester": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/acceptance-tester.md",
      "responsibilities": [
        "Generar E2E/integration tests desde AC-XX del PRD",
        "Capturar evidencia visual (screenshots, traces)",
        "Ejecutar tests y reportar resultados"
      ],
      "fileOwnership": ["test/acceptance/", "tests/acceptance/", ".quality/evidence/**/acceptance/"]
    },
    "AcceptanceValidator": {
      "model": "sonnet",
      "prompt": "agent-teams/prompts/acceptance-validator.md",
      "responsibilities": [
        "Validacion independiente de acceptance criteria",
        "Verificar implementacion contra PRD",
        "Emitir veredicto ACCEPTED/CONDITIONAL/REJECTED"
      ],
      "fileOwnership": [".quality/evidence/"]
    }
  },
  "communication": {
    "patterns": {
      "request": "Lead → Specialist (asignacion de tarea)",
      "report": "Specialist → Lead (tarea completada)",
      "broadcast": "Lead → All (cambio de plan)",
      "debate": "Specialist ↔ Specialist (decision tecnica)"
    }
  },
  "qualityGates": {
    "preCommit": {
      "flutter": "dart fix --apply && dart analyze && flutter test",
      "react": "npx eslint . --fix && npx tsc --noEmit && npx jest",
      "python": "ruff check . --fix && mypy . && pytest",
      "google-apps-script": "npm run test && npm run lint && npm run push"
    },
    "minCoverage": 85
  },
  "notes": {
    "activateRoles": "Activar solo los roles necesarios para el proyecto",
    "flutterOnly": "Si el proyecto es solo Flutter, usar: Lead + DesignSpecialist + FlutterSpecialist + DBInfra + QAReviewer",
    "reactOnly": "Si el proyecto es solo React, usar: Lead + DesignSpecialist + ReactSpecialist + DBInfra + QAReviewer",
    "appsScriptOnly": "Si el proyecto es solo Apps Script, usar: Lead + AppScriptSpecialist + QAReviewer",
    "fullStack": "Para full-stack, activar todos los roles relevantes"
  }
}
