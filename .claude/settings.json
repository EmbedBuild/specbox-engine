{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": {
          "tool_name": "Read"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/read-tracker.mjs",
            "blocking": false,
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Bash",
          "command_pattern": "git commit"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/commit-spec-guard.mjs",
            "blocking": true,
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-lint.mjs",
            "blocking": true,
            "timeout": 60000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/e2e-gate.mjs",
            "blocking": true,
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/checkpoint-freshness-guard.mjs",
            "blocking": false,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Bash",
          "command_pattern": "git push"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/uc-lifecycle-guard.mjs",
            "blocking": false,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Write",
          "input_contains": "src/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/spec-guard.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Write",
          "input_contains": "lib/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/spec-guard.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Edit",
          "input_contains": "src/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/spec-guard.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Edit",
          "input_contains": "lib/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/spec-guard.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Write",
          "input_contains": "presentation/pages/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/design-gate.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Edit",
          "input_contains": "presentation/pages/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/design-gate.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Write",
          "input_contains": "src/pages/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/design-gate.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Edit",
          "input_contains": "src/pages/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/design-gate.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Write",
          "input_contains": "app/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/design-gate.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Edit",
          "input_contains": "app/"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/design-gate.mjs",
            "blocking": true,
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": {
          "tool_name": "Write"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-first-guard.mjs",
            "blocking": true,
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/healing-budget-guard.mjs",
            "blocking": true,
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pipeline-phase-guard.mjs",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Edit"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/quality-first-guard.mjs",
            "blocking": true,
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/healing-budget-guard.mjs",
            "blocking": true,
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pipeline-phase-guard.mjs",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Bash",
          "command_pattern": "--no-verify"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/no-bypass-guard.mjs",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Bash",
          "command_pattern": "push.*--force"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/no-bypass-guard.mjs",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Bash",
          "command_pattern": "push.*-f "
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/no-bypass-guard.mjs",
            "blocking": true,
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": {
          "tool_name": "Bash",
          "command_pattern": "reset --hard"
        },
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/no-bypass-guard.mjs",
            "blocking": true,
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/on-session-end.mjs",
            "blocking": false,
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
